# Port the Express auth server listens on locally.
PORT=4000

# Supabase connection - the auth server reads the admins table from here
# to verify login credentials. Same project as the web app's SQL DB.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Secrets used to sign JWTs. Two different secrets so a leaked access
# token secret can't be used to forge refresh tokens or vice versa.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Origin of the Next.js app, for CORS - only that origin may call this server.
WEB_APP_ORIGIN=http://localhost:3000
