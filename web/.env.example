# Supabase connection - Next.js API routes write/read the registrations
# and admins tables directly (Server 2 talks to the SQL DB itself).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MongoDB Atlas connection string - API routes read/write the devices
# collection (simulated LoRa device pings).
MONGODB_URI=

# Base URL of the Express auth server (Server 1). The admin login page
# and silent-refresh logic call this, they never touch Supabase directly
# for credential checks - the auth server owns that.
AUTH_SERVER_URL=http://localhost:4000
