# Supabase connection - Next.js API routes write/read the registrations
# and admins tables directly (Server 2 talks to the SQL DB itself).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# MongoDB Atlas connection string - API routes read/write the devices
# collection and the admin-editable site_settings collection.
MONGODB_URI=

# Same secret as auth-server/.env. Lets Next.js API routes verify an admin's
# access token themselves (signature + expiry check only, no DB/network
# call) instead of asking the auth server to confirm it on every request.
JWT_ACCESS_SECRET=

# Base URL of the Express auth server (Server 1), reachable from the browser.
# WHY NEXT_PUBLIC_: the admin login page calls this directly from client-side
# JS (that's where the httpOnly refresh cookie needs to be set), and only
# environment variables prefixed NEXT_PUBLIC_ are available in browser code.
NEXT_PUBLIC_AUTH_SERVER_URL=http://localhost:4000
